#!/bin/sh

set -eu

PHP_BIN="${PHP_BIN:-/opt/homebrew/bin/php}"

if [ ! -x "$PHP_BIN" ]; then
	echo "PHP binary not found at $PHP_BIN" >&2
	echo "Set PHP_BIN to your php path and try again." >&2
	exit 1
fi

find . -path './vendor' -prune -o -name '*.php' -type f -print | sort | while IFS= read -r file; do
	"$PHP_BIN" -l "$file"
done
